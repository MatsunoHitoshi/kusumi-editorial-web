generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContentType {
  page
  article
  project
  reading
  publication
}

enum ContentStatus {
  draft
  published
}

enum UserRole {
  admin
  editor
}

/** 固定ページ（type=page）の公開サイトでの表示モード */
enum PageDisplayMode {
  normal
  toc
  portfolio
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  passwordHash String
  role      UserRole @default(editor)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentDocument {
  id             String        @id @default(cuid())
  schemaVersion  Int           @default(1)
  type           ContentType
  slug           String
  title          String
  status         ContentStatus @default(draft)
  body           Json
  /** type=page のときのみ使用。それ以外は null */
  pageDisplayMode PageDisplayMode?
  /** type=page のときのみ使用。ポートフォリオ表示時の直下子ページ順序 */
  portfolioOrder Int?
  publishVersion String?
  publishedAt    DateTime?
  /** 論理削除日時。null のときのみ公開・一覧の対象 */
  deletedAt      DateTime?
  updatedAt      DateTime      @updatedAt
  createdAt      DateTime      @default(now())

  @@index([type, slug, status])
  @@index([status, publishVersion])
}
